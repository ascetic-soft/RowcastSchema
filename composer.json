{
    "name": "ascetic-soft/rowcast-schema",
    "description": "Schema-first migration tool for PDO databases, friendly to Rowcast",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "database",
        "schema",
        "migrations",
        "pdo",
        "yaml",
        "rowcast",
        "php"
    ],
    "authors": [
        {
            "name": "Andrey Borodulin",
            "email": "borodulin@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AsceticSoft\\RowcastSchema\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AsceticSoft\\RowcastSchema\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/rowcast-schema"
    ]
}
